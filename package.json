    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.1.9",
    "@tanstack/react-table": "^8.21.3",
    "@types/bad-words": "^3.0.3",
    "@types/pg": "^8.11.14",
    "@types/sanitize-html": "^2.15.0",
    "argon2": "^0.43.0",
