{
  "name": "rlinecms",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development next dev --turbo",
    "build": "NODE_ENV=production prisma generate && node scripts/generate-module-routes.mjs && next build",
    "db:deploy": "prisma migrate deploy",
    "generate:module-routes": "node scripts/generate-module-routes.mjs",
    "start": "NODE_ENV=production next start",
    "lint": "next lint",
    "typecheck": "tsc -p . --noEmit",
    "create-admin": "tsx src/scripts/create-admin.ts",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "test": "npx --yes vitest",
    "test:ci": "npx --yes vitest run",
    "test:coverage": "npx --yes vitest run --coverage",
    "test:ui": "npx --yes vitest --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
