    "pg": "^8.15.6",
    "prism-react-renderer": "^2.4.1",
    "prisma": "^6.19.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.56.1",
